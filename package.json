{
  "name": "@velocity-bpa/n8n-nodes-tradier",
  "version": "1.0.0",
  "description": "n8n community node for Tradier trading platform integration",
  "license": "SEE LICENSE IN LICENSE.md",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials",
    "lintfix": "eslint nodes credentials --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*"
  ],
  "n8n": {
    "credentials": [
      "dist/credentials/TradierApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Tradier/Tradier.node.js"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.1.0",
    "typescript": "~5.3.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.1.4",
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "tradier",
    "trading",
    "stocks",
    "options",
    "market-data"
  ]
}